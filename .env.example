# Ma'lumotlar bazasi jadvalini yaratish:
# Supabase SQL Editor ga o'tib, quyidagi SQL ni yurgizing:
#
# CREATE TABLE users (
#   id UUID PRIMARY KEY REFERENCES auth.users(id) ON DELETE CASCADE,
#   email TEXT,
#   display_name TEXT,
#   created_at TIMESTAMPTZ DEFAULT NOW(),
#   stats JSONB DEFAULT '{"gamesPlayed": 0, "totalCorrect": 0, "totalQuestions": 0, "bestScore": 0}',
#   last_game_at TIMESTAMPTZ,
#   last_mistakes JSONB
# );
#
# -- Row Level Security
# ALTER TABLE users ENABLE ROW LEVEL SECURITY;
# CREATE POLICY "Users can read own data" ON users
#   FOR SELECT USING (auth.uid() = id);
# CREATE POLICY "Users can insert own data" ON users
#   FOR INSERT WITH CHECK (auth.uid() = id);
# CREATE POLICY "Users can update own data" ON users
#   FOR UPDATE USING (auth.uid() = id);
#
# Authenticationni yoqish:
# Supabase → Authentication → Settings → Disable "Confirm email" (ixtiyoriy)
# Yoki pochtaga tasdiqlash xati yuborilishini qoldiring
